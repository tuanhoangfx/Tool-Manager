{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "P0020: Dev (terminal tích hợp)",
      "type": "shell",
      "command": "corepack pnpm dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "p0020-dev",
        "focus": false
      }
    }
  ]
}
