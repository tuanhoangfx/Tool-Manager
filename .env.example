# P0020-Data-Box — copy to .env.local (never commit secrets)

# Workspace PATs (e.g. SUPABASE_MANAGEMENT_TOKEN): use E:\Dev\.env.shared — see E:\Dev\.env.shared.example

# Optional override (default: https://databox.infi.io.vn in production)
# VITE_APP_ORIGIN=https://databox.infi.io.vn

# Tool Hub identity (default dev http://127.0.0.1:5176, prod https://infi.io.vn)
# VITE_TOOL_HUB_URL=http://127.0.0.1:5176

# Tool Hub Supabase (copy from P0004-Tool-Hub/.env.local) — sign-in user registry
VITE_HUB_SUPABASE_URL=https://fmnrafpzctuhxjaaomzt.supabase.co
VITE_HUB_SUPABASE_ANON_KEY=

# Data Box — Notes / Cookie vault (see docs/DATABOX-MIGRATION.md)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 2FA vault — dedicated project (see docs/TWOFA-SUPABASE.md) — czprofess P01 / zurfouqanjcubgneuctp
VITE_TWOFA_SUPABASE_URL=https://zurfouqanjcubgneuctp.supabase.co
VITE_TWOFA_SUPABASE_ANON_KEY=your-twofa-anon-key

# Transaction pooler — required for `pnpm db:migrate`
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# 2FA migrations — `pnpm twofa:db:apply`
TWOFA_SUPABASE_DB_URL=postgresql://postgres.zurfouqanjcubgneuctp:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Optional: full vault load-flow smoke (`pnpm verify:cookie-bridge` / CI secret P0020_PROBE_NOTE_ID)
P0020_PROBE_NOTE_ID=
