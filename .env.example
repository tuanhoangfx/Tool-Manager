# P0020-Data-Box — copy to .env.local (never commit secrets)

# Optional override (default: https://databox.infix1.io.vn in production)
# VITE_APP_ORIGIN=https://databox.infix1.io.vn

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: run `pnpm apply:cookie` (scripts/apply-all-p0020.mjs)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: full vault load-flow smoke (`pnpm verify:cookie-bridge` / CI secret P0020_PROBE_NOTE_ID)
P0020_PROBE_NOTE_ID=
