{
  "name": "p0020-data-box",
  "private": true,
  "version": "4.2.4",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "description": "P0020-Data-Box — unified data workspace for Notes, 2FA, secure cookie vault, and browser agents.",
