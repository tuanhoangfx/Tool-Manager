  "dependencies": {
    "@dev/hub-load": "file:./vendor/hub-load",
    "@supabase/supabase-js": "^2.106.1",
    "@tool-workspace/hub-identity": "file:./vendor/hub-identity",
    "@tool-workspace/hub-ui": "file:./vendor/hub-ui",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "otpauth": "^9.5.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
