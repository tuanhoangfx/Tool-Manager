    "db:migrate:batches": "node scripts/apply-batches-pg.mjs",
    "db:sync-manifest": "node scripts/sync-databox-manifest.mjs",
    "sync:e0001-databox": "node scripts/sync-e0001-databox.mjs",
    "apply:cookie": "node scripts/apply-all-p0020.mjs",
    "apply:fix-vnote": "node scripts/apply-fix-v-note.mjs",
    "apply:fix-vnote:api": "node scripts/apply-fix-v-note-api.mjs",
    "apply:route-activity:api": "node scripts/apply-route-activity-api.mjs",
    "apply:route-activity-sync:api": "node scripts/apply-route-activity-sync-api.mjs",
    "apply:route-activity-domain:api": "node scripts/apply-route-activity-domain-api.mjs",
    "apply:note-sync-touch:api": "node scripts/apply-note-sync-touch-api.mjs",
    "apply:synced-at-accessible:api": "node scripts/apply-synced-at-accessible-api.mjs",
    "apply:route-activity-list-fix:api": "node scripts/apply-route-activity-list-fix-api.mjs",
    "apply:route-activity-load-null:api": "node scripts/apply-route-activity-load-null-api.mjs",
    "db:url:clipboard": "node scripts/set-db-url-from-clipboard.mjs",
    "sync:extension": "node scripts/sync-extension-version.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "push": "powershell -ExecutionPolicy Bypass -File scripts/git-push.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 4176"
