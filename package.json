  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.4.0",
    "pg": "^8.21.0",
    "postcss": "^8.4.47",
    "supabase": "^2.101.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.9.3",
