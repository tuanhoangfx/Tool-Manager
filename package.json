{
  "name": "workspace-vault-hub",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "description": "P0020 Workspace Hub — unified Tool workspace for Notes, Todo, 2FA, secure cookie vault, and browser agents.",
  "author": "Tool Workspace",
  "scripts": {
    "dev": "node scripts/ensure-dev.cjs --open",
    "dev:fg": "node scripts/dev.cjs",
    "dev:vite": "vite --host 127.0.0.1 --port 5177",
    "daemon:start": "node scripts/ensure-dev.cjs",
    "daemon:stop": "pm2 delete p0020-dev && pm2 save",
    "daemon:status": "pm2 status p0020-dev",
    "open": "node scripts/ensure-dev.cjs --open",
    "build": "tsc --noEmit && vitest run --passWithNoTests && vite build",
    "verify:vault": "node scripts/verify-vault-v4.mjs",
    "verify:cookie": "node scripts/verify-p0020-schema.mjs",
    "verify:load-flow": "node scripts/verify-extension-load-flow.mjs",
    "supabase:version": "supabase --version",
    "supabase:query:file": "node scripts/supabase-query-file.mjs",
    "supabase:apply:versioned": "node scripts/supabase-query-file.mjs supabase/migrations/20260527113000_note_cookie_vault_versioned_sync.sql",
    "apply:cookie": "node scripts/apply-all-p0020.mjs",
    "apply:fix-vnote": "node scripts/apply-fix-v-note.mjs",
    "db:url:clipboard": "node scripts/set-db-url-from-clipboard.mjs",
    "sync:extension": "node scripts/sync-extension-version.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:p0019": "node scripts/sync-p0019-todo.cjs",
    "push": "powershell -ExecutionPolicy Bypass -File scripts/git-push.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 4176"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "otpauth": "^9.5.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.4.0",
    "pg": "^8.21.0",
    "postcss": "^8.4.47",
    "supabase": "^2.101.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.6"
  }
}
