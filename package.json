{
  "name": "tool-manager",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "description": "Tool Manager (P0020) — unified hub fork of P0004: catalog + Notes + Todo + 2FA + cookie sync.",
  "author": "Tool Workspace",
  "scripts": {
    "dev": "node scripts/dev-with-launcher.cjs",
    "dev:vite": "vite --host 127.0.0.1 --port 5177",
    "build": "tsc --noEmit && vitest run --passWithNoTests && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan:local": "node scripts/scan-local-workspace.cjs",
    "sync:workspace": "node scripts/sync-workspace-bidirectional.cjs",
    "sync:workspace:dry": "node scripts/sync-workspace-bidirectional.cjs --dry-run",
    "sync:workspace:clone": "node scripts/sync-workspace-bidirectional.cjs --clone-missing",
    "icons:sync": "node scripts/sync-thesvg-icons.cjs",
    "rules:sync": "node scripts/sync-rules-preview.cjs",
    "sync:p0019": "node scripts/sync-p0019-todo.cjs",
    "launcher": "node scripts/local-tool-launcher.cjs",
    "publish:github:init": "node scripts/publish-github-repo.cjs",
    "publish:github": "node scripts/publish-github-repo.cjs",
    "push": "powershell -ExecutionPolicy Bypass -File scripts/git-push.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 4176"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "otpauth": "^9.5.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.4.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.6"
  }
}
